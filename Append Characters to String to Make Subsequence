class Solution {
    public int appendCharacters(String s, String t) {
        int a = s.length();
        int b = t.length();
        
        int i = 0;
        int j = 0;

        while (i < a && j < b) {
            if (s.charAt(i) == t.charAt(j)) {
                j++;
            }
            i++;
        }

        return b - j;
    }
}
